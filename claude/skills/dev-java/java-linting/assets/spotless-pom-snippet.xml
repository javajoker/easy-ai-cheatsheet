<!-- Spotless Maven plugin snippet. Merge under <build><plugins> in pom.xml.
     Then run `mvn spotless:apply` to format and `mvn spotless:check` to verify. -->

<plugin>
  <groupId>com.diffplug.spotless</groupId>
  <artifactId>spotless-maven-plugin</artifactId>
  <version>2.43.0</version>
  <configuration>
    <java>
      <googleJavaFormat>
        <version>1.22.0</version>
      </googleJavaFormat>
      <removeUnusedImports/>
      <importOrder>
        <order>java,javax,org,com,</order>
      </importOrder>
      <trimTrailingWhitespace/>
      <endWithNewline/>
    </java>
    <pom>
      <sortPom/>
    </pom>
    <markdown>
      <includes><include>**/*.md</include></includes>
      <flexmark/>
    </markdown>
  </configuration>
  <executions>
    <execution>
      <id>spotless-check</id>
      <phase>verify</phase>
      <goals><goal>check</goal></goals>
    </execution>
  </executions>
</plugin>
